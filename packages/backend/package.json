{
  "name": "backend",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "version": "0.0.25",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./convex/api": {
      "import": "./src/_generated/api.js",
      "types": "./src/_generated/api.d.ts"
    },
    "./convex/server": {
      "import": "./src/_generated/server.js",
      "types": "./src/_generated/server.d.ts"
    },
    "./convex/dataModel": {
      "types": "./src/_generated/dataModel.d.ts"
    }
  },
  "files": [
    "dist",
    "src/_generated"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "npx tsup --watch & npx convex dev",
    "dev:push-env": "./scripts/setup-convex-env.sh push .env.local --environment development",
    "dev:pull-env": "./scripts/setup-convex-env.sh pull .env.local --environment development",
    "prod:push-env": "./scripts/setup-convex-env.sh push .env.local --environment production",
    "prod:pull-env": "./scripts/setup-convex-env.sh pull .env.local --environment production"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.90",
    "@convex-dev/rate-limiter": "^0.3.0",
    "@convex-dev/react-query": "^0.0.0-alpha.11",
    "@raideno/convex-analytics": "^0.0.2",
    "@raideno/convex-kv": "^0.1.0",
    "@raideno/convex-onboardings": "^0.0.4",
    "@raideno/convex-stripe": "^0.3.8",
    "convex": "^1.29.1",
    "convex-helpers": "^0.1.105",
    "fluent-convex": "^0.12.3",
    "oslo": "^1.2.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.2"
  }
}
